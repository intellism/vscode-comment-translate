{
    "version": "2.0.0",
    "tasks": [
        {
			"type": "shell",
			"command": "npm run webpack-dev",
			"label": "webpack-dev",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"isBackground": true,
			"problemMatcher": [
				{
					"owner": "webpack",
					"fileLocation": ["relative", "${workspaceFolder}"],
					"pattern": {
						"regexp": "^([^\\s].*)\\((\\d+|\\d+,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(TS\\d+)\\s*:\\s*(.*)$",
						"file": 1,
						"location": 2,
						"severity": 3,
						"code": 4,
						"message": 5
					},
					"background": {
						"activeOnStart": true,
						"beginsPattern": "webpack --mode development --watch",
						"endsPattern": "compiled successfully"
					}
				}
			]
		}
    ]
}
